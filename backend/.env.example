DATABASE_URL="postgresql://postgres:CHANGE_ME@127.0.0.1:5432/whistle"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
JWT_REFRESH_TTL_REMEMBER_ME="90d"
PORT=4000

# Redis (BullMQ background jobs — renewal reminders, rating recalculation).
# Optional in dev: the API boots without Redis; jobs run via ?sync=1 triggers.
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
