# Server-side base URL (used by Next.js Route Handlers proxying to the API).
API_URL=http://localhost:4000/api/v1
# Client-side base URL (used by browser code calling the API directly for
# everything except auth, which goes through the Route Handlers above so the
# refresh token can live in an httpOnly cookie).
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
